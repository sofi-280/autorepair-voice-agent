# ── Gemini (required) ─────────────────────────────────────────────
# Get your API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model (optional — default shown below)
GEMINI_MODEL=gemini-2.0-flash-live-001

# ── ShopMonkey (required for live data) ───────────────────────────
# Generate an API key: ShopMonkey → Settings → Integrations → API Keys
SHOPMONKEY_API_KEY=your_shopmonkey_api_key_here

# ── Shop branding ─────────────────────────────────────────────────
# The AI will use this name when greeting customers
SHOP_NAME=Mike's Auto Repair

# ── Twilio (optional — enables real SMS confirmations) ────────────
# Sign up at: https://www.twilio.com
# Without these keys the agent runs in demo mode (SMS logged to console only)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# The Twilio phone number that sends SMS (must be purchased in your Twilio account)
TWILIO_FROM_NUMBER=+15551234567

# ── Warm transfer (optional) ──────────────────────────────────────
# Phone number shown on dashboard when agent requests a human handoff
# In a full Twilio Voice integration this would be the number to dial
TRANSFER_NUMBER=+15559876543
